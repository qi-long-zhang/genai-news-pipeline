# MongoDB
# Full MongoDB connection string.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<options>
# Database name used by this project.
MONGO_DATABASE=<database_name>
# Comma-separated collection names. Order must match TARGET_ACCOUNTS.
MONGO_COLLECTIONS=mothership,straits_times,channel_news_asia

# X / Twitter API
# Comma-separated account handles. Order must match MONGO_COLLECTIONS.
TARGET_ACCOUNTS=<account_a,account_b,account_c>
# API key for twitterapi.io.
TWITTER_API_KEY=<twitter_api_key>

# Gemini API
# API key used for embeddings and content generation.
GEMINI_API_KEY=<gemini_api_key>
